<% layout("/layouts/boilerplate") %>

<h2 class="mt-3 mb-3">All Users</h2>

<div class="container">
  <div class="row">
    <% users.forEach(user => { %>
      <% if(user._id.toString() !== currentUser){ %>
        
        <div class="col-10 mb-3">
          <div class="card p-3 d-flex flex-row justify-content-between align-items-center">
            <div class="d-flex flex-row align-items-center" >
              <a href="/chat/<%= user._id %>" class="user-link pe-5">
                <%= user.username %>
              </a>

              <small class="text-muted">
                <% const lastMsg = lastMessageMap[user._id.toString()]; %>

                <% if(lastMsg){ %>

                  <% if(lastMsg.senderId == currentUser){ %>
                    You: <%= lastMsg.message %>
                  <% } else { %>
                    <%= lastMsg.message %>
                  <% } %>

                <% } else { %>
                  No messages yet
                <% } %>
              </small>
            </div>
            
            <div class="status">
              <span class="online-dot d-none" id="dot-<%= user._id %>"></span>
            </div>
          </div>
        </div>

      <% } %>
    <% }) %>
  </div>
</div>

<script>
  const currentUserId = "<%= currentUser %>";
</script>

<% block('js') %>
<script src="/socket.io/socket.io.js"></script>
<script src="/js/contact.js"></script>

<% block('css') %>
<link rel="stylesheet" href="/css/contact.css">

